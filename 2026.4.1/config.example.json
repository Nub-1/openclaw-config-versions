/**
 * OpenClaw Config Template v2026.4.1
 * 
 * วิธีใช้: Copy ไฟล์นี้เป็น config.json แล้วแทนที่ค่า REDACTED ด้วยค่าจริงของคุณ
 * 
 * ดูค่าจริงจาก: openclaw config get
 */

// ===== META =====
"meta": {
  "lastTouchedVersion": "2026.4.1",
  "lastTouchedAt": "2026-04-02T08:20:00.000Z"
},

// ===== WIZARD =====
"wizard": {
  "lastRunAt": "2026-03-05T12:46:19.556Z",
  "lastRunVersion": "2026.3.1-beta.1",
  "lastRunCommand": "doctor",
  "lastRunMode": "local"
},

// ===== AGENTS DEFAULTS =====
"agents": {
  "defaults": {
    "model": "minimax/MiniMax-M2.7",          // Model ที่ใช้เลยเริ่มต้น
    "contextPruning": {
      "mode": "cache-ttl",
      "ttl": "1h"
    },
    "compaction": {
      "mode": "safeguard"
    },
    "timeoutSeconds": 600,                    // 10 นาที (เพิ่มจาก 60 วินาที)
    "heartbeat": {
      "every": "30m"
    },
    "sandbox": {
      "mode": "off"
    },
    "maxConcurrent": 4,                       // 🆕 จำนวน agent พร้อมกันได้
    "subagents": {
      "maxConcurrent": 8                       // 🆕 จำนวน subagent พร้อมกันได้
    }
  }
},

// ===== COMMANDS =====
"commands": {
  "native": "auto",
  "nativeSkills": "auto",
  "restart": true,
  "ownerDisplay": "raw"
},

// ===== CHANNELS =====
"channels": {
  "telegram": {
    "enabled": true,
    "dmPolicy": "allowlist",
    "botToken": "แทนที่ด้วย Telegram Bot Token ของคุณ",  // เช่น 123456789:ABCdefGHIjklMNO...
    "allowFrom": ["แทนที่ด้วย Telegram Chat ID ของคุณ"],  // เช่น 123456789
    "groupPolicy": "allowlist",
    "streaming": "off",
    "execApprovals": {
      "enabled": false,
      "approvers": ["แทนที่ด้วย Chat ID ที่อนุญาต"]
    }
  },
  "discord": {
    "enabled": true,
    "token": {
      "source": "env",                         // หรือ "direct"
      "provider": "default",
      "id": "แทนที่ด้วย DISCORD_BOT_TOKEN env variable name"
    },
    "groupPolicy": "allowlist",
    "streaming": "off",
    "dmPolicy": "allowlist",
    "allowFrom": ["แทนที่ด้วย Discord User ID"]
  },
  "line": {
    "enabled": true,
    "channelAccessToken": "แทนที่ด้วย LINE Channel Access Token",
    "channelSecret": "แทนที่ด้วย LINE Channel Secret",
    "dmPolicy": "allowlist",
    "groupPolicy": "allowlist",
    "allowFrom": ["แทนที่ด้วย LINE User ID"]
  }
},

// ===== GATEWAY =====
"gateway": {
  "mode": "local",
  "bind": "lan",
  "controlUi": {
    "allowedOrigins": [
      "http://localhost:18789",
      "http://127.0.0.1:18789"
    ],
    "dangerouslyAllowHostHeaderOriginFallback": false,
    "allowInsecureAuth": false
  },
  "auth": {
    "mode": "token",
    "rateLimit": {
      "maxAttempts": 10,
      "windowMs": 60000,
      "lockoutMs": 300000
    }
  }
},

// ===== PLUGINS =====
"plugins": {
  "entries": {
    "unraidclaw": {
      "enabled": true,
      "config": {
        "serverUrl": "https://แทนที่ด้วย Unraid Server URL",  // เช่น https://192.168.1.100:9876
        "apiKey": "แทนที่ด้วย Unraid API Key",
        "tlsSkipVerify": true
      }
    },
    "line": {
      "enabled": true,
      "config": {}
    },
    "minimax": {
      "enabled": true,
      "config": {}
    }
  }
},

// ===== TOOLS =====
"tools": {
  "profile": "full",
  "elevated": {
    "enabled": true,
    "allowFrom": {
      "telegram": ["แทนที่ด้วย Chat ID ที่อนุญาต exec สูง"]
    }
  },
  "exec": {
    "security": "full",
    "ask": "off"
  }
},

// ===== MESSAGES =====
"messages": {
  "ackReactionScope": "group-mentions"         // 🆕
}
